# ============================================================
# BioPropose Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.
# ============================================================

# ---- DAL (Data Access Layer) --------------------------------
# The BAL (API) talks to the DAL over this URL.
# In Docker Compose this is http://dal:5000 (internal network).
# For local dev outside Docker, run the DAL separately and set:
DAL_URL=http://localhost:5000
# Shared secret — must match DAL_API_KEY on the DAL container.
DAL_API_KEY=change-me-strong-random-secret

# ---- DAL Service (set when running apps/dal directly) ------
DAL_PORT=5000

# ---- MySQL --------------------------------------------------
# These are used by the DAL (and the migrate service).
# The BAL never touches the database directly.
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=
DB_NAME=biopropose
DB_SSL=false
DB_POOL_MAX=20
DB_POOL_MIN=5

# ---- BAL (Business Logic Layer / API) ----------------------
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ---- AI Provider -------------------------------------------
# Options: ollama | claude
# Switch with a single env var — no code changes or rebuild needed.
AI_PROVIDER=ollama

# Ollama — local LLM (used when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120000

# Claude / Anthropic (used when AI_PROVIDER=claude)
# AI_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# CLAUDE_MODEL=claude-sonnet-4-6

# ---- Qdrant Vector DB (for RAG / semantic search) ----------
# Run locally: docker run -p 6333:6333 qdrant/qdrant
# Port 32768 is the default mapped port in docker-compose.
QDRANT_URL=http://localhost:6333

# ---- Export (PDF / Word) -----------------------------------
EXPORT_DIR=./exports
EXPORT_TIMEOUT=30000
PUPPETEER_HEADLESS=true

# ---- Email -------------------------------------------------
# Transport options: console (dev) | smtp | sendgrid | ses
EMAIL_TRANSPORT=console
EMAIL_FROM=noreply@biopropose.local

# SMTP
# EMAIL_TRANSPORT=smtp
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password

# SendGrid
# EMAIL_TRANSPORT=sendgrid
# SENDGRID_API_KEY=SG.your-key-here

# AWS SES
# EMAIL_TRANSPORT=ses
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_REGION=us-east-1

# ---- File Storage ------------------------------------------
# Options: local | s3
STORAGE_TYPE=local

# S3
# STORAGE_TYPE=s3
# AWS_S3_BUCKET=biopropose-exports
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_REGION=us-east-1

# ---- Logging -----------------------------------------------
LOG_LEVEL=info
# Options: pretty (dev) | json (prod)
LOG_FORMAT=pretty

# ---- Error Tracking (Sentry) --------------------------------
# Leave blank to disable.
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ---- Salesforce Integration --------------------------------
# Feature is disabled when SFDC_CLIENT_ID is absent.
# SFDC_LOGIN_URL=https://login.salesforce.com
# SFDC_CLIENT_ID=your-connected-app-client-id
# SFDC_CLIENT_SECRET=your-connected-app-client-secret
# SFDC_USERNAME=your-sf-username@example.com
# SFDC_PASSWORD=your-sf-password
# SFDC_API_VERSION=v59.0
# SFDC_OPP_SEARCH_FIELD=Name

# ---- Frontend (Vite build args — set at docker-compose build time) --
# VITE_API_URL=http://localhost:4000
# VITE_WS_URL=ws://localhost:4001
