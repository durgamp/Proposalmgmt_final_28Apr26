{
  "name": "biopropose",
  "version": "1.0.0",
  "private": true,
  "description": "Biologics RFI/RFP Proposal Management Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w api\" \"npm run dev -w web\"",
    "dev:api": "npm run dev -w api",
    "dev:web": "npm run dev -w web",
    "dev:ws": "npm run ws -w api",
    "build": "npm run build -w @biopropose/shared-types && npm run build -w @biopropose/database && npm run build -w api && npm run build -w web",
    "db:migrate": "npm run migrate -w @biopropose/database",
    "db:migrate:prod": "npm run migrate:prod -w @biopropose/database",
    "db:seed": "npm run seed -w @biopropose/database",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
