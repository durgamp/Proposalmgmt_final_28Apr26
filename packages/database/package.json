{
  "name": "@biopropose/database",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./seed": {
      "import": "./dist/seed.js",
      "require": "./dist/seed.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "migrate": "ts-node -r tsconfig-paths/register src/migrate.ts",
    "migrate:prod": "NODE_ENV=production ts-node -r tsconfig-paths/register src/migrate.ts",
    "seed": "ts-node -r tsconfig-paths/register src/seed.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "mysql2": "^3.10.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
